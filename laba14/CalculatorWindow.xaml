<Window x:Class="laba14.CalculatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:laba14"
        mc:Ignorable="d"
          Title="Задание 1: Калькулятор" Height="450" Width="350">
    <Grid>
  
        <StackPanel Margin="20">
            <Label Content="Введите число А:"/>
            <TextBox x:Name="txtNumA" ToolTip="Только цифры"/>

            <Label Content="Введите число Б:"/>
            <TextBox x:Name="txtNumB" />

            <Label Content="Выберите операцию:"/>
            <ComboBox x:Name="cbOperation" Margin="5" Height="30" SelectedIndex="0">
                <ComboBoxItem Content="Сложение (+)"/>
                <ComboBoxItem Content="Вычитание (-)"/>
                <ComboBoxItem Content="Умножение (*)"/>
                <ComboBoxItem Content="Деление (/)"/>
                <ComboBoxItem Content="Возведение в степень (^)"/>
                <ComboBoxItem Content="Остаток от деления (%)"/>
            </ComboBox>

            <Button Content="ВЫЧИСЛИТЬ" Click="Calculate_Click" Margin="5,20,5,5" Background="#FFD11279"/>

            <Border BorderBrush="Gray" BorderThickness="1" Margin="5,20,5,5" Padding="10">
                <TextBlock x:Name="lblResult" Text="Результат: " FontSize="16" FontWeight="Bold" Foreground="DarkGreen" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>