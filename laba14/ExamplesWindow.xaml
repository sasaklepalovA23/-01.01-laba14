<Window x:Class="laba14.ExamplesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:laba14"
        mc:Ignorable="d"
        Title="Примеры из лекции" Height="200" Width="400">
    <StackPanel Margin="20">
        <Label Content="Пример привязки (Label к TextBox):" Background="#FFEBD4E0"/>
        <TextBox x:Name="entryBox" Text="Введите текст..." Margin="0,10"/>

        <Label Content="{Binding ElementName=entryBox, Path=Text}" 
               Background="#FFDCA4C2" BorderBrush="Black" BorderThickness="1"/>
    </StackPanel>
</Window>